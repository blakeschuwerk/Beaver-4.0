{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://beaver.dev/schemas/raw-document.json",
  "title": "RawDocumentMessage",
  "type": "object",
  "required": ["schema_version", "trace_id", "published_at", "gcs_uri", "document_id", "county_id", "content_hash", "doc_type"],
  "properties": {
    "schema_version": { "type": "string", "default": "1.0.0" },
    "trace_id": { "type": "string", "format": "uuid" },
    "published_at": { "type": "string", "format": "date-time" },
    "gcs_uri": { "type": "string" },
    "document_id": { "type": "string" },
    "county_id": { "type": "string" },
    "content_hash": { "type": "string" },
    "doc_type": {
      "type": "string",
      "enum": ["agenda", "packet", "minutes", "rfp", "scope_of_work", "tabulation", "bid_roster", "other"]
    },
    "source_url": { "type": "string", "format": "uri" },
    "meeting_date": { "type": "string" }
  },
  "additionalProperties": false
}
