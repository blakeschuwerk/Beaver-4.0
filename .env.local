# Auto-generated by scripts/setup-qwen.sh — do not commit
LLM_ENDPOINT_URL=http://localhost:11434/v1/chat/completions
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_LOCAL_ONLY=true
SCRAPER_REAL=true
