# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
FIRESTORE_DATABASE=beaver-firebase

# BigQuery
BQ_DATASET=beaver_pipeline

# GCS
GCS_RAW_BUCKET=beaver-raw-documents
GCS_STAGING_BUCKET=beaver-staging-extracted

# Pub/Sub topics (defaults match packages/shared constants)
# PUBSUB_TOPIC_SCRAPE_JOBS=scrape-jobs
# PUBSUB_TOPIC_PROJECTS_CREATED=projects-created

# LLM (external — RunPod or compatible OpenAI-style endpoint)
LLM_ENDPOINT_URL=https://your-runpod-endpoint/v1/chat/completions
LLM_API_KEY=your-api-key
LLM_MOCK_MODE=true

# Local dev
PORT=8080
MOCK_MODE=true
