# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
FIRESTORE_DATABASE=beaver-firebase

# BigQuery
BQ_DATASET=beaver_pipeline

# GCS
GCS_RAW_BUCKET=beaver-raw-documents
GCS_STAGING_BUCKET=beaver-staging-extracted

# Pub/Sub topics (defaults match packages/shared constants)
# PUBSUB_TOPIC_SCRAPE_JOBS=scrape-jobs
# PUBSUB_TOPIC_PROJECTS_CREATED=projects-created

# LLM (external — always called for real, no mock mode)
# Production: RunPod or compatible OpenAI-style endpoint.
LLM_ENDPOINT_URL=https://your-runpod-endpoint/v1/chat/completions
LLM_API_KEY=your-api-key

# Local dev: point at a local model server instead and set LLM_LOCAL_ONLY=true so the
# classifier/personalization LLM clients refuse to run against a non-local endpoint.
# Petals volunteer-compute gateway (see scripts/petals/ + functions/classifier/petals-gateway/)
# is one option:
# LLM_ENDPOINT_URL=http://localhost:8000/v1/chat/completions
# LLM_LOCAL_ONLY=true
# LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# PETALS_INITIAL_PEERS=/ip4/<your-public-ip>/tcp/31337/p2p/<your-peer-id>

# Local dev
PORT=8080
MOCK_MODE=true

# Feature flags (default = safe fallbacks; flip after plugging in outlets — see OUTLETS.md)
SCRAPER_REAL=false
USE_DOCLING=false

# F5 matching thresholds
MATCH_MIN_RELEVANCE=0.5
MATCH_MAX_PER_PROJECT=10
