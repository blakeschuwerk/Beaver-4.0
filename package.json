{
  "name": "beaver-4.0",
  "version": "0.1.0",
  "private": true,
  "description": "Beaver 4.0 — Government meeting document pipeline for early-stage infrastructure project discovery",
  "scripts": {
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @beaver/shared build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:dispatcher": "pnpm --filter @beaver/dispatcher dev",
    "dev:classifier": "pnpm --filter @beaver/classifier dev",
    "dev:personalization": "pnpm --filter @beaver/personalization dev",
    "dev:api": "MOCK_MODE=true pnpm --filter @beaver/api dev",
    "dev:frontend": "VITE_MOCK_MODE=true pnpm --filter @beaver/frontend dev",
    "seed": "node scripts/seed.mjs",
    "seed:counties": "node scripts/seed-counties.mjs",
    "check:county-links": "node scripts/check-county-links.mjs",
    "test:integration": "node scripts/integration-test.mjs",
    "test:python": "cd functions/scraper && PYTHONPATH=. python3 -m pytest tests/ -q && cd ../analyzer && PYTHONPATH=. python3 -m pytest tests/ -q",
    "qwen:setup": "bash scripts/setup-qwen.sh",
    "llama:setup": "bash scripts/setup-qwen.sh",
    "local:scrape-extract": ".venv/bin/python scripts/local_pipeline.py",
    "local:demo": ".venv/bin/python scripts/local_pipeline.py --demo",
    "local:classify": "node scripts/local-classify.mjs",
    "local:run": "pnpm local:scrape-extract && pnpm build && pnpm local:classify",
    "local:run:demo": "pnpm local:demo && pnpm build && pnpm local:classify"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
